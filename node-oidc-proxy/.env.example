# ---- Server ----
PORT=8080
LOG_LEVEL=info

# ---- OIDC (BC Gov Keycloak "standard" realm) ----
OIDC_ISSUER=https://test.loginproxy.gov.bc.ca/auth/realms/standard
OIDC_CLIENT_ID=eo-dmi-geoserver-cloud-alz-6502
OIDC_CLIENT_SECRET=change-me-from-key-vault
OIDC_REDIRECT_URI=https://your-public-host/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=https://your-public-host/
OIDC_SCOPES=openid profile email

# ---- Session cookie (stateless, encrypted) ----
# Must be >= 32 bytes. Generate e.g. `openssl rand -base64 48`.
SESSION_COOKIE_SECRET=change-me-at-least-32-bytes-long-secret
SESSION_COOKIE_NAME=gs_sso
SESSION_MAX_AGE_SECONDS=43200

# ---- Upstream gateway (internal GeoServer Cloud) ----
GATEWAY_ORIGIN=https://gateway.internal.your-env-domain
GATEWAY_TLS_INSECURE=false
# Optional tuning (defaults shown):
# GATEWAY_CONNECT_TIMEOUT_MS=5000
# GATEWAY_READ_TIMEOUT_MS=60000

# ---- Public-facing identity ----
PUBLIC_ORIGIN=https://your-public-host
IDENTITY_HEADER=sec-username
USERNAME_CLAIM=preferred_username
# Display name injected for GeoServer's UI (human-readable label, not used for
# role lookups). The header is only sent when the claim is present in the token.
DISPLAY_NAME_HEADER=sec-user-display-name
DISPLAY_NAME_CLAIM=display_name
MACHINE_AUTH_PASSTHROUGH=true

# ---- pgconfig DB (optional) ----
# Used by db.ts to upsert each IDIR user into gssec.user_display_names on login.
# Leave blank to disable (the pool is only created when host/database/username
# are all set). Injected on the proxy ACA app by Terraform.
PGCONFIG_HOST=
PGCONFIG_PORT=5432
PGCONFIG_DATABASE=
PGCONFIG_USERNAME=
PGCONFIG_PASSWORD=

# ---- GeoServer admin REST (optional) ----
# Used by geoserver.ts to register each IDIR user (by GUID) in the default
# user/group service so they appear under Security -> Users/Groups in the UI.
# Disabled unless GEOSERVER_ADMIN_PASSWORD is set. Calls the same internal
# gateway as GATEWAY_ORIGIN. Roles still come from the JDBC role service.
GEOSERVER_ADMIN_USERNAME=admin
GEOSERVER_ADMIN_PASSWORD=
GEOSERVER_BASE_PATH=/geoserver/cloud
# GEOSERVER_USERGROUP_SERVICE=default
# GEOSERVER_REST_TIMEOUT_MS=5000

# Optional convenience redirect target for "/"
# DEFAULT_RETURN_TO=/geoserver/cloud/web/
